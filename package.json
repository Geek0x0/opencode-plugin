  "name": "opencode-llm-stats-sidebar",
  "version": "1.0.0",
  "description": "OpenCode TUI sidebar plugin for LLM request statistics",
  "type": "module",
  "main": "dist/index.js",
  "author": "",
  "license": "MIT",
  "keywords": [
